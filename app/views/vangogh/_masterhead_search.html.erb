<div class="masthead-searchbox-container">
  <div id="searchboxInc" class="r">
    <form id="frm" name="frm" method="get" action="" class="">
      <h3 class=""><span class="glyphicon glyphicon-search" aria-hidden="true"></span>&nbsp;<span class="">Find my Best Works</span></h3>
      <div class="help-block text-muted">200+ interfaces for web, mobile, tv and more…</div>
      <div class="form-group"></div>
      <fieldset>
        <p class="error hide">Oops! We need at least part of the name to start searching.</p>
        <div class="form-group">
          <h4><label for="destination">Designer Name:</label></h4>
          <span class="help-block text-muted">E.g. Rodrigo Quaresma</span>
          <input class="form-control input-lg hide" type="text" />
          <div>
            <input id="search_autocomplete" class="form-control input-lg typeahead" type="text" placeholder="States of USA" data-provide="typeahead" autocomplete="off">
          </div>
        </div>
        <%= link_to "Let's go!", vangogh_results_path, class: "btn btn-secundary btn-lg pull-right" %>
      </fieldset>
    </form>
  </div>
</div>

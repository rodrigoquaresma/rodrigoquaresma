<div class="masthead-searchbox-container">
  <div id="searchboxInc" class="r">
    <form id="frm" name="frm" method="get" action="" class="">
      <h3 class=""><span class="glyphicon glyphicon-search" aria-hidden="true"></span>&nbsp;<span class="">You found me!</span></h3>
      <div class="help-block text-muted">Almost 20 years making interfaces for web, mobile, tv and more…</div>
      <div class="form-group"></div>
      <fieldset>
        <p class="error hide">Oops! We need at least part of the name to start searching.</p>
        <div class="form-group">
          <h4><label for="destination">It's me, your new designer:</label></h4>
          <input class="form-control input-lg hide" type="text" />
          <div>
            <input class="form-control input-lg typeahead" type="text" placeholder="" value="Rodrigo Quaresma" disabled />
          </div>
        </div>
        <%= link_to "Let's go!", vangogh_results_path, class: "btn btn-secundary btn-lg pull-right" %>
      </fieldset>
    </form>
  </div>
</div>
